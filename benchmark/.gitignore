# Per-system PDB/CIF data for the hosted app — regenerated by prep/, not committed.
# (The demo/systems/ copy IS committed on purpose so the static demo is self-contained.)
/app/systems/

# Foldseek build-time caches (large; regenerated by build_training_similarity.py).
_refcache/
_fshits/

# Backup / log / experiment cruft.
*.bak
*.bak_*
*.log

# Python.
__pycache__/
*.pyc
*.pyo

# OS.
.DS_Store
